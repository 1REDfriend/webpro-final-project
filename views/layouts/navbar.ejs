<nav class="navbar">
    <a href="/" class="navbar-brand"><img class="navbar-logo" src="/logo.svg" alt="logo">Student</a>
    <button class="navbar-toggle" id="navToggle" aria-label="เมนู" onclick="toggleNav()">
        <span></span>
        <span></span>
        <span></span>
    </button>
    <div class="navbar-menu" id="navMenu">
        <% if (user) { %>
            <span>
                <%= user.full_name %> (<%= user.role.toUpperCase() %>)
            </span>

            <% if (user.role==='student' ) { %>
                <a href="/student/dashboard">หน้าหลัก</a>
                <a href="/student/grades">ผลการเรียน</a>
                <a href="/student/schedule">ตารางเรียน</a>
                <a href="/student/requests">คำร้อง</a>
                <% } %>

                    <% if (user.role==='teacher' ) { %>
                        <a href="/teacher/dashboard">หน้าหลัก</a>
                        <a href="/teacher/classes">รายชื่อห้อง</a>
                        <a href="/teacher/schedule">ตารางสอน</a>
                        <a href="/teacher/requests">คำร้อง</a>
                        <% } %>

                            <% if (user.role==='staff' ) { %>
                                <a href="/staff/dashboard">จัดการคำร้อง</a>
                                <% } %>

                                    <% if (user.role==='executive' ) { %>
                                        <a href="/executive/dashboard">ภาพรวม</a>
                                        <a href="/executive/teachers">จัดการครู</a>
                                        <a href="/executive/students">จัดการนักเรียน</a>
                                        <% } %>

                                            <a href="/logout" class="logout-btn">ออกจากระบบ</a>
                                            <% } %>
    </div>
</nav>
<script>
    function toggleNav() {
        const menu = document.getElementById('navMenu');
        menu.classList.toggle('open');
    }
    // Close nav when a link is clicked (useful on mobile)
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.navbar-menu a').forEach(function (link) {
            link.addEventListener('click', function () {
                document.getElementById('navMenu').classList.remove('open');
            });
        });
    });
</script>